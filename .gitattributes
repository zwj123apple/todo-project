# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Shell scripts should always use LF
*.sh text eol=lf

# Windows batch files should always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Source code
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Configuration files
*.properties text eol=lf
*.conf text eol=lf
*.config text eol=lf

# SQL files
*.sql text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Binary files (don't modify these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.jar binary
*.war binary
*.ear binary
*.class binary
*.so binary
*.dll binary
*.exe binary